{
  "name": "trello-api-postman-newman-jenkins",
  "version": "1.0.0",
  "description": "API testing project using Postman, Newman and Jenkins for Trello API.",
  "scripts": {
    "test": "newman run collections/trello-api.postman_collection.json",
    "test:report": "newman run collections/trello-api.postman_collection.json -r cli,htmlextra --reporter-htmlextra-export reports/newman-report.html"
  },
  "devDependencies": {
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1"
  }
}